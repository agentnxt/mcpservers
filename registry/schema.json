{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agentnxt/mcp-registry/blob/main/registry/schema.json",
  "title": "AgentNxt MCP Registry WebApplication Entry",
  "description": "JSON-LD compatible registry entry for MCP servers modeled as schema.org WebApplication with MCP-specific operational metadata under mcp.",
  "type": "object",
  "required": [
    "@context",
    "@type",
    "identifier",
    "name",
    "description",
    "applicationCategory",
    "applicationSubCategory",
    "browserRequirements",
    "runtimePlatform",
    "softwareRequirements",
    "featureList",
    "installUrl",
    "license",
    "permissions",
    "provider",
    "mcp"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "@context": {
      "oneOf": [
        { "type": "string", "const": "https://schema.org" },
        {
          "type": "object",
          "required": ["@vocab", "mcp"],
          "additionalProperties": { "type": "string" },
          "properties": {
            "@vocab": { "type": "string", "const": "https://schema.org/" },
            "mcp": { "type": "string" }
          }
        }
      ]
    },
    "@type": { "type": "string", "const": "WebApplication" },
    "@id": { "type": "string" },
    "identifier": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "url": { "type": "string" },
    "sameAs": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "applicationCategory": { "type": "string" },
    "applicationSubCategory": { "type": "string" },
    "browserRequirements": { "type": "string" },
    "runtimePlatform": { "type": "string" },
    "operatingSystem": { "type": "string" },
    "softwareRequirements": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      ]
    },
    "softwareVersion": { "type": "string" },
    "featureList": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      ]
    },
    "installUrl": { "type": "string" },
    "downloadUrl": { "type": "string" },
    "softwareHelp": { "type": "string" },
    "releaseNotes": { "type": "string" },
    "license": { "type": "string" },
    "permissions": { "type": "string" },
    "provider": {
      "type": "object",
      "required": ["@type", "name"],
      "additionalProperties": false,
      "properties": {
        "@type": { "type": "string", "enum": ["Organization", "Person"] },
        "name": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "mcp": {
      "type": "object",
      "required": [
        "status",
        "category",
        "source",
        "transports",
        "deployment",
        "auth",
        "tools",
        "maintainers"
      ],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["draft", "experimental", "stable", "deprecated"] },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" }, "default": [] },
        "source": {
          "type": "object",
          "required": ["type", "url"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["local", "upstream", "remote", "container"] },
            "url": { "type": "string" },
            "package": { "type": "string" },
            "license": { "type": "string" }
          }
        },
        "transports": {
          "type": "array",
          "items": { "type": "string", "enum": ["stdio", "sse", "streamable-http", "http"] },
          "minItems": 1
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "language": { "type": "string" },
            "minimumVersion": { "type": "string" }
          }
        },
        "deployment": {
          "type": "object",
          "required": ["recommended", "docker"],
          "additionalProperties": false,
          "properties": {
            "recommended": { "type": "string", "enum": ["docker", "npx", "pipx", "remote", "cloud-run", "custom"] },
            "docker": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "image": { "type": "string" },
                "dockerfile": { "type": "string" },
                "ports": { "type": "array", "items": { "type": "string" } }
              }
            },
            "local": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "command": { "type": "string" },
                "args": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "auth": {
          "type": "object",
          "required": ["type", "requiredEnv"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string" },
            "requiredEnv": { "type": "array", "items": { "type": "string" } },
            "optionalEnv": { "type": "array", "items": { "type": "string" }, "default": [] },
            "notes": { "type": "string" }
          }
        },
        "tools": { "type": "array", "items": { "type": "string" } },
        "maintainers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "links": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
