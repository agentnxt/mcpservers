{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/agentnxt/mcp-registry/blob/main/registry/schema.json",
  "$comment": "Permissive, incrementally extensible Schema.org WebApplication profile for AgentNxt MCP registry entries. Nothing is mandatory. Known fields are validated when present. Unknown Schema.org and MCP extension fields are allowed. Use mcp.canonicalId as the stable MCP server identity. Use @id, identifier, url, sameAs, about, and mainEntity to link to the canonical entity described by the record.",
  "title": "AgentNxt MCP Registry WebApplication Profile",
  "description": "A non-blocking JSON-LD/Schema.org profile for MCP registry entries. Records may start partial and be enriched over time.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "@context": {
      "oneOf": [
        { "type": "string" },
        { "type": "object", "additionalProperties": true }
      ]
    },
    "@type": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "@id": { "type": "string", "format": "uri-reference" },
    "identifier": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/propertyValue" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/$defs/propertyValue" }
            ]
          }
        }
      ]
    },
    "url": { "type": "string", "format": "uri-reference" },
    "sameAs": { "$ref": "#/$defs/stringOrStringArray" },
    "mainEntity": { "$ref": "#/$defs/thingOrUrl" },
    "mainEntityOfPage": { "$ref": "#/$defs/thingOrUrl" },
    "about": { "$ref": "#/$defs/thingOrUrlOrArray" },
    "name": { "type": "string" },
    "alternateName": { "$ref": "#/$defs/stringOrStringArray" },
    "description": { "type": "string" },
    "disambiguatingDescription": { "type": "string" },
    "image": { "$ref": "#/$defs/thingOrUrlOrArray" },
    "applicationCategory": { "$ref": "#/$defs/textOrUrl" },
    "applicationSubCategory": { "$ref": "#/$defs/textOrUrl" },
    "applicationSuite": { "type": "string" },
    "availableOnDevice": { "type": "string" },
    "browserRequirements": { "type": "string" },
    "countriesSupported": { "$ref": "#/$defs/stringOrStringArray" },
    "countriesNotSupported": { "$ref": "#/$defs/stringOrStringArray" },
    "downloadUrl": { "type": "string", "format": "uri-reference" },
    "featureList": { "$ref": "#/$defs/textOrUrlOrArray" },
    "fileSize": { "type": "string" },
    "installUrl": { "type": "string", "format": "uri-reference" },
    "memoryRequirements": { "$ref": "#/$defs/textOrUrl" },
    "operatingSystem": { "$ref": "#/$defs/textOrObjectOrArray" },
    "permissions": { "$ref": "#/$defs/textOrTextArray" },
    "processorRequirements": { "type": "string" },
    "releaseNotes": { "$ref": "#/$defs/textOrUrl" },
    "runtimePlatform": { "$ref": "#/$defs/textOrObjectOrArray" },
    "screenshot": { "$ref": "#/$defs/thingOrUrlOrArray" },
    "softwareAddOn": { "$ref": "#/$defs/thingOrArray" },
    "softwareHelp": { "$ref": "#/$defs/thingOrUrl" },
    "softwareRequirements": { "$ref": "#/$defs/textOrUrlOrObjectOrArray" },
    "softwareVersion": { "type": "string" },
    "storageRequirements": { "$ref": "#/$defs/textOrUrl" },
    "supportingData": { "$ref": "#/$defs/thingOrArray" },
    "abstract": { "type": "string" },
    "accessMode": { "$ref": "#/$defs/textOrTextArray" },
    "accessModeSufficient": {
      "oneOf": [
        { "$ref": "#/$defs/thing" },
        { "type": "array", "items": { "$ref": "#/$defs/thing" } }
      ]
    },
    "accessibilityAPI": { "$ref": "#/$defs/textOrTextArray" },
    "accessibilityControl": { "$ref": "#/$defs/textOrTextArray" },
    "accessibilityFeature": { "$ref": "#/$defs/textOrTextArray" },
    "accessibilityHazard": { "$ref": "#/$defs/textOrTextArray" },
    "accessibilitySummary": { "type": "string" },
    "accountablePerson": { "$ref": "#/$defs/thing" },
    "audience": { "$ref": "#/$defs/thingOrArray" },
    "author": { "$ref": "#/$defs/thingOrArray" },
    "creator": { "$ref": "#/$defs/thingOrArray" },
    "copyrightHolder": { "$ref": "#/$defs/thingOrArray" },
    "copyrightNotice": { "type": "string" },
    "copyrightYear": {
      "oneOf": [
        { "type": "string" },
        { "type": "integer" }
      ]
    },
    "dateCreated": { "type": "string" },
    "dateModified": { "type": "string" },
    "datePublished": { "type": "string" },
    "encodingFormat": { "$ref": "#/$defs/stringOrStringArray" },
    "genre": { "$ref": "#/$defs/stringOrStringArray" },
    "inLanguage": { "$ref": "#/$defs/stringOrStringArray" },
    "isAccessibleForFree": { "type": "boolean" },
    "isFamilyFriendly": { "type": "boolean" },
    "keywords": { "$ref": "#/$defs/stringOrStringArray" },
    "license": { "$ref": "#/$defs/textOrUrl" },
    "offers": { "$ref": "#/$defs/thingOrArray" },
    "publisher": { "$ref": "#/$defs/thingOrArray" },
    "review": { "$ref": "#/$defs/thingOrArray" },
    "aggregateRating": { "$ref": "#/$defs/thing" },
    "provider": { "$ref": "#/$defs/thing" },
    "mcp": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "canonicalId": {
          "type": "string",
          "description": "Stable MCP server identity. Prefer a DID, for example did:web:agentnxt.dev:mcp:servers:google-analytics, or another globally resolvable URI controlled by the publisher."
        },
        "id": {
          "type": "string",
          "description": "Human-friendly local registry slug or legacy server ID. Prefer mcp.canonicalId for stable identity."
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Previous IDs, package names, upstream names, or alternate registry slugs that should resolve to this server."
        },
        "namespace": { "type": "string" },
        "status": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "source": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string" },
            "url": { "type": "string", "format": "uri-reference" },
            "package": { "type": "string" },
            "license": { "type": "string" }
          }
        },
        "transports": { "type": "array", "items": { "type": "string" } },
        "runtime": { "type": "object", "additionalProperties": true },
        "deployment": { "type": "object", "additionalProperties": true },
        "auth": { "type": "object", "additionalProperties": true },
        "tools": { "type": "array", "items": { "type": "string" } },
        "maintainers": { "type": "array", "items": { "type": "string" } },
        "links": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "thing": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@type": { "type": "string" },
        "@id": { "type": "string", "format": "uri-reference" },
        "identifier": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/propertyValue" }
          ]
        },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri-reference" },
        "sameAs": { "$ref": "#/$defs/stringOrStringArray" }
      }
    },
    "propertyValue": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "@type": { "type": "string" },
        "propertyID": { "type": "string" },
        "value": { "type": ["string", "number", "boolean", "null"] },
        "url": { "type": "string", "format": "uri-reference" }
      }
    },
    "textOrUrl": { "type": "string" },
    "textOrTextArray": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "textOrUrlOrArray": { "$ref": "#/$defs/textOrTextArray" },
    "textOrObjectOrArray": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/thing" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/$defs/thing" }
            ]
          }
        }
      ]
    },
    "textOrUrlOrObjectOrArray": { "$ref": "#/$defs/textOrObjectOrArray" },
    "stringOrStringArray": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "thingOrUrl": {
      "oneOf": [
        { "$ref": "#/$defs/thing" },
        { "type": "string", "format": "uri-reference" }
      ]
    },
    "thingOrUrlOrArray": {
      "oneOf": [
        { "$ref": "#/$defs/thing" },
        { "type": "string", "format": "uri-reference" },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/thing" },
              { "type": "string", "format": "uri-reference" }
            ]
          }
        }
      ]
    },
    "thingOrArray": {
      "oneOf": [
        { "$ref": "#/$defs/thing" },
        { "type": "array", "items": { "$ref": "#/$defs/thing" } }
      ]
    }
  }
}
